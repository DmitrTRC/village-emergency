# База API (пусто = тот же origin; в dev можно указать http://localhost:8787)
VITE_API_BASE=
# Публичный VAPID-ключ для web-push (НЕ секрет; приватный живёт на сервере)
VITE_VAPID_PUBLIC_KEY=
# Username Telegram-бота для deep-link логина/регистрации (без @)
VITE_TG_BOT=village_emrg_bot
# Шаблон URL растровых тайлов карты (по умолчанию публичный OSM; для прода
# заменить на провайдера с ключом — у OSM строгий usage policy)
VITE_MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
