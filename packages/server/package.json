{
  "name": "@village/server",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "seed:houses": "tsx src/seed-houses.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/s3-request-presigner": "^3.1068.0",
    "@hono/node-server": "^2.0.5",
    "@hono/zod-validator": "^0.8.0",
    "@village/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "grammy": "^1.44.0",
    "hono": "^4.6.0",
    "jose": "^6.2.3",
    "pino": "^9",
    "postgres": "^3.4.0",
    "uuidv7": "^1.0.0",
    "web-push": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.1",
    "@types/node": "^22.0.0",
    "@types/web-push": "^3.6.0",
    "drizzle-kit": "^0.31.0",
    "testcontainers": "^10.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.6"
  }
}
